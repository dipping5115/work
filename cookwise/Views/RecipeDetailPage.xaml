<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:cookwise.ViewModels"
             x:Class="cookwise.Views.RecipeDetailPage"
             Title="Recipe">
    <ContentPage.BindingContext>
        <vm:RecipeDetailViewModel />
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="{Binding Recipe.Name}" FontSize="28" FontAttributes="Bold" TextColor="#FF6B35"/>
            <Label Text="{Binding Recipe.Description}" FontSize="14" TextColor="Gray"/>

            <Frame BackgroundColor="#E8F5E9" Padding="12">
                <Grid ColumnDefinitions="*,*,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                        <Label Text="Home" FontSize="10" TextColor="Green"/>
                        <Label Text="{Binding Recipe.EstimatedCost, StringFormat='${0:F2}'}" FontSize="14" FontAttributes="Bold" TextColor="Green"/>
                    </VerticalStackLayout>
                    <Label Text="VS" FontSize="16" TextColor="Gray" Grid.Column="1" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label Text="Delivery" FontSize="10" TextColor="Red"/>
                        <Label Text="$12.00" FontSize="14" FontAttributes="Bold" TextColor="Red"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame BackgroundColor="#FFF3E0" Padding="15">
                <VerticalStackLayout>
                    <Label Text="Servings" FontSize="16" FontAttributes="Bold" TextColor="#E65100"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,10,0,0">
                        <Button Text="-" Command="{Binding DecreaseServingsCommand}" WidthRequest="40" HeightRequest="40" Grid.Column="0" BackgroundColor="#FF6B35"/>
                        <Label Text="{Binding CurrentServings, StringFormat='{0} servings'}" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" Grid.Column="1"/>
                        <Button Text="+" Command="{Binding IncreaseServingsCommand}" WidthRequest="40" HeightRequest="40" Grid.Column="2" BackgroundColor="#FF6B35"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Ingredients" FontSize="18" FontAttributes="Bold"/>
            <Frame BackgroundColor="#F5F5F5" Padding="15">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Recipe.Ingredients}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <Label Text="{Binding Name}" Grid.Column="0"/>
                                <Label Text="{Binding Grams, StringFormat='{0}g'}" Grid.Column="1" TextColor="#FF6B35" FontAttributes="Bold"/>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Steps" FontSize="18" FontAttributes="Bold"/>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Recipe.Steps}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" Padding="12" Margin="0,5">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Frame BackgroundColor="#FF6B35" WidthRequest="30" HeightRequest="30" Grid.Column="0">
                                        <Label Text="{Binding StepNumber}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontAttributes="Bold"/>
                                    </Frame>
                                    <Label Text="{Binding Description}" FontSize="14" Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0"/>
                                </Grid>
                                
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding HeatLevel, StringFormat='Heat: {0}'}" FontSize="12" TextColor="Gray" VerticalOptions="Center"/>
                                    <Button Text="{Binding DurationMinutes, StringFormat='Timer {0}min'}" 
                                            Command="{Binding Source={x:Reference TimerButton}, Path=BindingContext.StartTimerCommand}"
                                            CommandParameter="{Binding}"
                                            x:Name="TimerButton"
                                            BackgroundColor="#4CAF50" 
                                            TextColor="White"
                                            FontSize="12"
                                            HeightRequest="35"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Frame BackgroundColor="#D32F2F" Padding="15" IsVisible="{Binding HasActiveTimer}">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="Cooking..." FontSize="16" TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="{Binding ActiveTimerDisplay}" FontSize="36" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                    <Button Text="Stop" Command="{Binding StopTimerCommand}" BackgroundColor="White" TextColor="#D32F2F"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Add Note" Command="{Binding AddNoteCommand}" BackgroundColor="#9C27B0" TextColor="White" Margin="0,10,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
