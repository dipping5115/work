<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:cookwise.ViewModels"
             x:Class="cookwise.Views.SearchPage"
             Title="Search">
    <ContentPage.BindingContext>
        <vm:SearchViewModel />
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Search" FontSize="24" FontAttributes="Bold" TextColor="#FF6B35"/>
            <Label Text="Enter ingredients to find recipes" FontSize="14" TextColor="Gray"/>

            <Frame BackgroundColor="#F5F5F5" Padding="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry x:Name="IngredientEntry" Placeholder="Tomato, Egg" Text="{Binding IngredientInput, Mode=TwoWay}" Grid.Column="0"/>
                    <Button Text="Add" Command="{Binding AddIngredientCommand}" BackgroundColor="#FF6B35" TextColor="White" Grid.Column="1" Margin="10,0,0,0"/>
                </Grid>
            </Frame>

            <Label Text="Selected" FontSize="14" FontAttributes="Bold"/>
            <FlexLayout Wrap="Wrap" BindableLayout.ItemsSource="{Binding SelectedIngredients}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#E3F2FD" Padding="10,5" Margin="0,0,5,5">
                            <Label Text="{Binding}" VerticalOptions="Center"/>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <Button Text="Search Recipes" Command="{Binding SearchCommand}" BackgroundColor="#4CAF50" TextColor="White" FontSize="16" HeightRequest="45"/>

            <Label Text="Results" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding SearchResults}" HeightRequest="400">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" Padding="15">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Recipe.Name}" FontSize="18" FontAttributes="Bold"/>
                                <Label Text="{Binding Recipe.Description}" FontSize="12" TextColor="Gray"/>
                                <Button Text="View" Command="{Binding Source={x:Reference IngredientEntry}, Path=BindingContext.ViewRecipeCommand}" CommandParameter="{Binding Recipe}" BackgroundColor="#FF6B35" TextColor="White"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
