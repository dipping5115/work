<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:cookwise.ViewModels"
             x:Class="cookwise.Views.NotePage"
             Title="Notes">
    <ContentPage.BindingContext>
        <vm:NoteViewModel />
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Taste Notes" FontSize="24" FontAttributes="Bold" TextColor="#FF6B35"/>
            <Label Text="Record your cooking experience" FontSize="14" TextColor="Gray"/>

            <Frame BackgroundColor="#F5F5F5" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Add Note" FontSize="16" FontAttributes="Bold"/>
                    <Entry Placeholder="Recipe Name" Text="{Binding NewNote.RecipeName, Mode=TwoWay}"/>
                    <Editor Placeholder="Notes" HeightRequest="80" Text="{Binding NewNote.AdjustmentsText, Mode=TwoWay}"/>
                    <Button Text="Save" Command="{Binding SaveNoteCommand}" BackgroundColor="#4CAF50" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="My Notes" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding UserNotes}" HeightRequest="300">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" Padding="12">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding RecipeName}" FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding AdjustmentsText}" FontSize="12" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Frame BackgroundColor="#FFF3E0" Padding="15">
                <VerticalStackLayout>
                    <Label Text="Flavor Profile" FontSize="18" FontAttributes="Bold" TextColor="#E65100"/>
                    <Button Text="View Profile" Command="{Binding ViewProfileCommand}" BackgroundColor="#FF6B35" TextColor="White"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
